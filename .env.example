# Qualcomm Cloud AI (Cirrascale Inference Cloud)
# Get your API key at: https://aisuite.cirrascale.com/account/api-keys
QUALCOMM_AI_API_KEY=your_cirrascale_api_key_here
QUALCOMM_AI_API_URL=https://aisuite.cirrascale.com/apis/v2/chat/completions
QUALCOMM_AI_MODEL=Llama-3.3-70B

# ElevenLabs TTS (optional — system works text-only without this)
# Sign up at elevenlabs.io, free tier is plenty for demos
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=hmMWXCj9K7N5mCPcRkfC

# Hub server
HUB_HOST=0.0.0.0
HUB_PORT=8080

# Arduino UNO Q controller
CONTROLLER_UDP_PORT=9877

# Version storage directory
VERSIONS_DIR=versions

# HTTPS — required for real-device WebXR without Chrome flags
# Generate a self-signed cert:
#   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes
USE_HTTPS=false
SSL_CERT_FILE=cert.pem
SSL_KEY_FILE=key.pem
